# /home/anilrai/Desktop/Chatbot/AI Chatbot/.env.example
# backend/.env is loaded by the backend service via env_file
# frontend/.env is read by Vite at BUILD time, not runtime
# Root .env is read by docker-compose.yml for MONGO_USER/MONGO_PASS

# MongoDB (used by docker-compose.yml directly)
MONGO_USER=
MONGO_PASS=

# Backend (backend/.env)
OPENAI_API_KEY=
MONGODB_URI=mongodb://MONGO_USER:MONGO_PASS@mongo:27017/antigravity?authSource=admin
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PORT=4000
NODE_ENV=production

# Frontend (frontend/.env — baked in at build time)
VITE_API_URL=http://localhost/api
